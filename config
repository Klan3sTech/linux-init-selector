# init-selector configuration
# This file is generated by install.sh
# Format:
#   DEFAULT=<name>
#   <name> <path>
#
# <name> is one of: systemd, openrc, runit, dinit, sysvinit, s6,
#                   shepherd, finit, sinit, epoch, busybox-init
# <path> is absolute path on the real root filesystem
# Last selected init is saved to /etc/init-selector/last on root
#
# Note: install.sh generates this file from real detection. Generic /sbin/init
# entries are commented here because on many systems /sbin/init is systemd.

DEFAULT=systemd
systemd /usr/lib/systemd/systemd
openrc /sbin/openrc-init
runit /sbin/runit-init
dinit /sbin/dinit
# sysvinit /sbin/init
# s6 /etc/s6-linux-init/current/bin/init
# shepherd /usr/bin/shepherd
# finit /sbin/finit
# sinit /sbin/sinit
# epoch /sbin/epoch
# busybox-init /sbin/init
